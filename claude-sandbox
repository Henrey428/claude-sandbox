#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────
# claude-sandbox — Launch a devcontainer with multiple repos
#
# Usage:
#   # Explicit main repo
#   claude-sandbox --main org/main-repo [--repo org/other-repo ...] [OPTIONS]
#
#   # From inside a git repo (auto-detects current repo + branch)
#   claude-sandbox
#   claude-sandbox --branch other-branch
#   claude-sandbox --repo org/extra-repo
#
# Examples:
#   # Auto-detect: sandbox current repo on current branch
#   claude-sandbox
#
#   # Auto-detect: current repo on a different branch
#   claude-sandbox --branch feature-x
#
#   # Auto-detect: current repo + extra repo
#   claude-sandbox --repo myorg/shared-lib@feature-x
#
#   # Explicit: single repo
#   claude-sandbox --main myorg/api-service
#
#   # Explicit: multi-repo
#   claude-sandbox \
#     --main myorg/api-service@fix-auth \
#     --repo myorg/shared-lib
# ─────────────────────────────────────────────────────────────

MAIN_REPO=""
MAIN_BRANCH=""
BRANCH_OVERRIDE=""
EXTRA_REPOS=()    # "org/repo" entries
EXTRA_BRANCHES=() # corresponding branch per repo ("" if none)
CLAUDE_PROMPT=""
DEVCONTAINER_DIR=""

usage() {
  cat << 'EOF'
Usage:
  claude-sandbox [OPTIONS]                                       (auto-detect from current git repo)
  claude-sandbox --main org/repo[@branch] [OPTIONS]              (explicit main repo)

Options:
  --main org/repo[@branch]   Main repo. Append @branch for a specific branch.
                             If omitted, auto-detects from current git directory.
  --branch <branch>          Override branch for the main repo (useful with auto-detect).
  --repo org/repo[@branch]   Additional repo. Repeat for multiple. Append @branch per repo.
  --claude "prompt"          Run Claude Code non-interactively with this prompt.
  --dir /path                Override the devcontainer project directory.
  -h, --help                 Show this help.

Examples:
  claude-sandbox                                                 # current repo, current branch
  claude-sandbox --branch feature-x                              # current repo, different branch
  claude-sandbox --repo myorg/lib@feature-x                      # current repo + extra repo
  claude-sandbox --main myorg/api@main --repo myorg/lib          # explicit
EOF
  exit 1
}

# Parse repo[@branch] into repo and branch parts
parse_repo_ref() {
  local ref="$1"
  if [[ "$ref" == *"@"* ]]; then
    echo "${ref%@*}" "${ref##*@}"
  else
    echo "$ref" ""
  fi
}

while [[ $# -gt 0 ]]; do
  case $1 in
    --main)
      read -r MAIN_REPO MAIN_BRANCH <<< "$(parse_repo_ref "$2")"
      shift 2 ;;
    --repo)
      read -r repo branch <<< "$(parse_repo_ref "$2")"
      EXTRA_REPOS+=("$repo")
      EXTRA_BRANCHES+=("$branch")
      shift 2 ;;
    --branch)     BRANCH_OVERRIDE="$2"; shift 2 ;;
    --claude)     CLAUDE_PROMPT="$2"; shift 2 ;;
    --dir)        DEVCONTAINER_DIR="$2"; shift 2 ;;
    -h|--help)    usage ;;
    *)            echo "Unknown option: $1"; usage ;;
  esac
done

# ─── Auto-detect from current git repo if --main not provided ───
if [[ -z "$MAIN_REPO" ]]; then
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: --main is required (or run from inside a git repo)"
    usage
  fi
  REMOTE_URL=$(git remote get-url origin 2>/dev/null || true)
  if [[ -z "$REMOTE_URL" ]]; then
    echo "Error: no 'origin' remote found in current git repo"
    exit 1
  fi
  # Extract org/repo from SSH or HTTPS URL
  MAIN_REPO=$(echo "$REMOTE_URL" | sed -E 's|^git@github\.com:|/|;s|^https://github\.com/||;s|\.git$||;s|^/||')
  MAIN_BRANCH=$(git branch --show-current 2>/dev/null || echo "")
  echo "==> Auto-detected repo: $MAIN_REPO${MAIN_BRANCH:+ @ $MAIN_BRANCH}"
fi

# --branch overrides the main repo branch
if [[ -n "$BRANCH_OVERRIDE" ]]; then
  MAIN_BRANCH="$BRANCH_OVERRIDE"
fi

# ─── Resolve devcontainer project dir ───
if [[ -z "$DEVCONTAINER_DIR" ]]; then
  # Default: use a temp project dir named after the main repo
  SANDBOX_NAME="sandbox-$(basename "$MAIN_REPO")-$$"
  DEVCONTAINER_DIR="/tmp/$SANDBOX_NAME"
fi

echo "==> Setting up devcontainer project at $DEVCONTAINER_DIR"
mkdir -p "$DEVCONTAINER_DIR/.devcontainer"

# Copy devcontainer config (assumes they live next to this script)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cp "$SCRIPT_DIR/.devcontainer/devcontainer.json" "$DEVCONTAINER_DIR/.devcontainer/"
cp "$SCRIPT_DIR/.devcontainer/setup.sh" "$DEVCONTAINER_DIR/.devcontainer/"

# ─── Generate an init script that clones repos inside the container ───
cat > "$DEVCONTAINER_DIR/.devcontainer/init-repos.sh" << INIT
#!/usr/bin/env bash
set -euo pipefail

WORKSPACE_DIR="/workspaces/$(basename "$DEVCONTAINER_DIR")"
REPOS_DIR="\$WORKSPACE_DIR/repos"
mkdir -p "\$REPOS_DIR"

clone_repo() {
  local repo="\$1"
  local branch="\$2"
  local name="\$(basename "\$repo")"
  local target="\$REPOS_DIR/\$name"

  if [ -d "\$target" ]; then
    echo "  ↻ \$name already cloned, pulling latest..."
    git -C "\$target" pull --ff-only 2>/dev/null || true
  else
    echo "  ⬇ Cloning \$repo → \$target"
    git clone "git@github.com:\$repo.git" "\$target"
  fi

  # Check out branch if specified
  if [ -n "\$branch" ]; then
    echo "  ↳ Checking out branch: \$branch"
    git -C "\$target" fetch origin "\$branch" 2>/dev/null || true
    git -C "\$target" checkout "\$branch" 2>/dev/null || \
      git -C "\$target" checkout -b "\$branch" "origin/\$branch" 2>/dev/null || \
      echo "  ⚠ Could not check out \$branch (creating as new branch from HEAD)"
    git -C "\$target" checkout -b "\$branch" 2>/dev/null || true
  fi
}

echo "==> Cloning repositories..."

# Main repo
clone_repo "$MAIN_REPO" "$MAIN_BRANCH"
MAIN_NAME="\$(basename "$MAIN_REPO")"
ln -sfn "\$REPOS_DIR/\$MAIN_NAME" "\$WORKSPACE_DIR/main"
echo "  ★ Main repo: \$MAIN_NAME"

# Extra repos
INIT

for i in "${!EXTRA_REPOS[@]}"; do
  repo="${EXTRA_REPOS[$i]}"
  branch="${EXTRA_BRANCHES[$i]}"
  echo "clone_repo \"$repo\" \"$branch\"" >> "$DEVCONTAINER_DIR/.devcontainer/init-repos.sh"
done

cat >> "$DEVCONTAINER_DIR/.devcontainer/init-repos.sh" << 'FOOTER'

echo ""
echo "==> Workspace ready. Layout:"
echo ""
ws-status 2>/dev/null || ls -la "$REPOS_DIR/"
echo ""
echo "Commands: ws-status, ws-cd <repo>, ws-main, wt-add <branch>"
FOOTER

chmod +x "$DEVCONTAINER_DIR/.devcontainer/init-repos.sh"

# ─── Patch postCreateCommand to also run init-repos ───
# We chain it: setup.sh runs first, then init-repos.sh
sed -i '' 's|"postCreateCommand":.*|"postCreateCommand": "bash .devcontainer/setup.sh \&\& bash .devcontainer/init-repos.sh",|' \
  "$DEVCONTAINER_DIR/.devcontainer/devcontainer.json"

# ─── Launch ───
echo "==> Starting devcontainer..."
echo "    Main repo:  $MAIN_REPO${MAIN_BRANCH:+ @ $MAIN_BRANCH}"
for i in "${!EXTRA_REPOS[@]}"; do
  b="${EXTRA_BRANCHES[$i]}"
  echo "    Extra repo: ${EXTRA_REPOS[$i]}${b:+ @ $b}"
done
echo ""

# Ensure devcontainer CLI is available
if ! command -v devcontainer &> /dev/null; then
  echo "Error: devcontainer CLI not found. Install with: npm install -g @devcontainers/cli"
  exit 1
fi

devcontainer up --workspace-folder "$DEVCONTAINER_DIR"

# Get the container ID for cleanup
CONTAINER_ID=$(docker ps -q --filter "label=devcontainer.local_folder=$DEVCONTAINER_DIR")

cleanup() {
  echo ""
  echo "==> Cleaning up sandbox..."
  if [[ -n "$CONTAINER_ID" ]]; then
    docker rm -f "$CONTAINER_ID" > /dev/null 2>&1 && echo "    Container removed."
  fi
  rm -rf "$DEVCONTAINER_DIR" && echo "    Temp directory removed."
}
trap cleanup EXIT

CONTAINER_WORKSPACE="/workspaces/$(basename "$DEVCONTAINER_DIR")"

if [[ -n "$CLAUDE_PROMPT" ]]; then
  echo "==> Running Claude Code with prompt..."
  devcontainer exec --workspace-folder "$DEVCONTAINER_DIR" \
    bash -c "cd $CONTAINER_WORKSPACE/main && claude --dangerously-skip-permissions -p '${CLAUDE_PROMPT//\'/\'\\\'\'}'"
else
  echo "==> Dropping into shell (main repo is at $CONTAINER_WORKSPACE/main)..."
  devcontainer exec --workspace-folder "$DEVCONTAINER_DIR" \
    bash -c "cd $CONTAINER_WORKSPACE/main && exec bash"
fi